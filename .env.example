NVIDIA_NIM_API_KEY=your-key-here
HF_TOKEN=

# Local llama.cpp server (optional — set to enable local model testing).
# Start it via `docker compose -f compose.llama-cpp.yml up -d` after
# running `./scripts/swap-local-model.sh <id>` to pick a model.
LOCAL_LLM_BASE_URL=
# Pin local runs to a single catalog id. Leave blank to list all local
# models in the dashboard (but remember llama-server only serves one).
LOCAL_LLM_MODEL=
